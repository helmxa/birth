<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ОТЕЦ • РЕАЛЬНЫЕ КОРАБЛИ EVE ONLINE • ВЕРФЬ</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Arial', sans-serif;
            background: #03050a;
            color: #e5f0ff;
            overflow-x: hidden;
            scroll-behavior: smooth;
        }

        /* ========== КОСМИЧЕСКИЙ ФОН ========== */
        #background {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: radial-gradient(ellipse at 60% 40%, #0b1b30, #010101);
        }

        .nebula {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.3;
            mix-blend-mode: screen;
            animation: nebulaFloat 80s infinite alternate;
        }
        .nebula1 { width: 100vmax; height: 100vmax; background: #1d4e7c; top: -20%; left: -20%; }
        .nebula2 { width: 140vmin; height: 140vmin; background: #6f4f9f; bottom: 0%; right: 0%; filter: blur(140px); opacity: 0.25; animation-duration: 110s; }
        .nebula3 { width: 200vmin; height: 200vmin; background: #2b6f6f; top: 40%; left: 20%; opacity: 0.2; filter: blur(200px); }

        @keyframes nebulaFloat {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(6%, 6%) scale(1.15); }
        }

        #stars-layer {
            position: fixed;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }
        .star {
            position: absolute;
            background: white;
            border-radius: 50%;
            box-shadow: 0 0 15px #cde1ff;
            animation: twinkle 4s infinite alternate;
        }
        @keyframes twinkle {
            0% { opacity: 0.2; transform: scale(1); }
            100% { opacity: 1; transform: scale(1.6); }
        }

        /* ========== ОСНОВНОЙ КОНТЕЙНЕР ========== */
        .scroll-container {
            position: relative;
            z-index: 20;
            max-width: 1400px;
            margin: 0 auto;
            padding: 30px 20px 100px;
        }

        /* СЕКЦИЯ 1 — ПРИВЕТСТВИЕ */
        .hero-section {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .command-panel {
            background: rgba(2, 15, 30, 0.65);
            backdrop-filter: blur(25px);
            border: 3px solid rgba(70, 160, 255, 0.5);
            border-radius: 100px 100px 50px 50px;
            padding: 70px 50px;
            width: 100%;
            box-shadow: 0 50px 100px rgba(0, 10, 40, 0.9), 0 0 0 3px rgba(100, 200, 255, 0.3) inset, 0 0 150px #2a5faa55;
            text-align: center;
        }

        h1 {
            font-size: 5.5rem;
            font-weight: 800;
            letter-spacing: 15px;
            text-transform: uppercase;
            background: linear-gradient(145deg, #fff8e7, #adcbff, white);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 50px #269;
            margin-bottom: 20px;
        }

        .captain {
            font-size: 2.5rem;
            color: #ffd58c;
            text-shadow: 0 0 30px #f90;
            border-top: 3px solid #446688;
            border-bottom: 3px solid #446688;
            display: inline-block;
            padding: 15px 40px;
            letter-spacing: 6px;
        }

        .father-name {
            font-size: 5rem;
            font-weight: 900;
            background: linear-gradient(145deg, #ffe27a, #ffffff);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 20px 0 10px;
            text-transform: uppercase;
        }

        .scroll-hint {
            font-size: 1.8rem;
            margin-top: 60px;
            opacity: 0.8;
            animation: bounce 2s infinite;
        }
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(15px); }
        }

        /* СЕКЦИЯ 2 — ВЕРФЬ С РЕАЛЬНЫМИ КОРАБЛЯМИ */
        .assembly-section {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .section-title {
            font-size: 3.5rem;
            text-transform: uppercase;
            background: linear-gradient(145deg, #b5d8ff, #f0f9ff);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 60px;
            letter-spacing: 8px;
            text-shadow: 0 0 30px #3a7bcb;
        }

        .assembly-machine {
            background: rgba(0, 5, 15, 0.8);
            backdrop-filter: blur(35px);
            border: 3px solid #3f9eff;
            border-radius: 120px;
            padding: 50px 40px;
            width: 100%;
            max-width: 1200px;
            box-shadow: 0 0 90px #1f5faf, inset 0 0 40px #2a5a9a;
        }

        /* Статистика */
        .stats-row {
            display: flex;
            flex-wrap: wrap;
            gap: 25px;
            justify-content: center;
            margin: 30px 0;
        }
        .stat-block {
            background: #0a1a2f;
            border: 2px solid #3f7ec6;
            border-radius: 60px;
            padding: 25px 35px;
            min-width: 200px;
            flex: 1 1 200px;
            text-align: center;
            transition: 0.2s;
        }
        .stat-block:hover {
            border-color: #ffbb44;
            box-shadow: 0 0 60px #fa0;
        }
        .stat-label {
            font-size: 1.3rem;
            color: #b2d3ff;
        }
        .stat-number {
            font-size: 3.2rem;
            font-weight: 700;
            color: #ffdf99;
            line-height: 1.2;
        }

        /* КОНВЕЙЕР С РЕАЛЬНЫМ ИЗОБРАЖЕНИЕМ */
        .conveyor {
            background: #081624;
            border-radius: 100px;
            padding: 30px;
            margin: 40px 0;
            border: 1px solid #4a7db0;
            box-shadow: inset 0 0 40px #0a1c32;
        }

        .ship-display-area {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }

        /* КОНТЕЙНЕР С РЕАЛЬНОЙ КАРТИНКОЙ КОРАБЛЯ */
        .ship-image-container {
            width: 100%;
            min-height: 400px;
            background: rgba(0, 0, 0, 0.5);
            border-radius: 80px;
            border: 3px solid #4a9eff;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            box-shadow: 0 0 80px #1f5faf, inset 0 0 30px #2a5a9a;
            overflow: hidden;
        }

        .ship-real-image {
            max-width: 100%;
            max-height: 380px;
            object-fit: contain;
            border-radius: 40px;
            filter: drop-shadow(0 0 40px #6ab5ff);
            transition: transform 0.3s;
        }
        .ship-real-image:hover {
            transform: scale(1.02);
        }

        .ship-name-tag {
            font-size: 2.8rem;
            font-weight: bold;
            color: #ffd966;
            text-shadow: 0 0 30px #f90;
            background: rgba(0, 20, 40, 0.9);
            padding: 15px 50px;
            border-radius: 60px;
            border: 2px solid #f90;
            margin-top: 15px;
            letter-spacing: 3px;
        }

        .build-panel {
            display: flex;
            gap: 30px;
            justify-content: center;
            flex-wrap: wrap;
            margin: 30px 0 20px;
        }

        .build-btn {
            background: #1f3f68;
            border: none;
            border-radius: 60px;
            padding: 20px 60px;
            font-size: 2rem;
            font-weight: 700;
            color: #fff2bf;
            border: 3px solid #fc6;
            cursor: pointer;
            box-shadow: 0 0 50px #fa0;
            transition: 0.2s;
            backdrop-filter: blur(10px);
        }
        .build-btn:hover {
            background: #2f5790;
            border-color: #ffe29c;
            color: white;
            box-shadow: 0 0 100px #ffaa33;
            transform: scale(1.02);
        }

        .build-log {
            font-family: 'Courier New', monospace;
            background: #030f1c;
            padding: 25px;
            border-radius: 50px;
            margin: 40px 0 20px;
            border: 1px solid #5380b3;
            color: #aad0ff;
            font-size: 1.3rem;
            max-height: 150px;
            overflow-y: auto;
        }

        /* СЕКЦИЯ 3 — ПЛЮШКИ */
        .booster-section {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .booster-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            width: 100%;
            max-width: 1200px;
            margin: 40px 0;
        }

        .booster-card {
            background: rgba(0, 12, 27, 0.75);
            backdrop-filter: blur(15px);
            border: 2px solid #4e90d0;
            border-radius: 60px;
            padding: 40px 20px;
            text-align: center;
            box-shadow: 0 0 60px #1d3d66;
            transition: 0.3s;
        }
        .booster-card:hover {
            border-color: #fdb24b;
            box-shadow: 0 0 90px #f80;
            transform: translateY(-10px);
        }
        .booster-icon { font-size: 4rem; margin-bottom: 20px; }
        .booster-title { font-size: 2.2rem; color: #ffd58c; margin-bottom: 20px; }
        .booster-desc { font-size: 1.3rem; color: #c4dcff; }

        .final-message {
            font-size: 2rem;
            background: rgba(0, 34, 68, 0.8);
            border-radius: 120px;
            padding: 50px 40px;
            border-left: 15px solid #ffae42;
            border-right: 15px solid #ffae42;
            margin-top: 40px;
            text-align: center;
        }
        .signature-code {
            font-family: monospace;
            background: #121f33;
            padding: 15px 40px;
            border-radius: 60px;
            font-size: 2rem;
            border: 2px dashed #65a9ff;
            color: #ffd966;
            display: inline-block;
            margin: 30px 0;
        }
        footer { text-align: center; padding: 40px 0 20px; color: #557799; }

        @media (max-width: 700px) {
            h1 { font-size: 3.2rem; }
            .father-name { font-size: 3rem; }
            .ship-name-tag { font-size: 1.8rem; }
            .ship-image-container { min-height: 250px; }
        }
    </style>
</head>
<body>
    <div id="background">
        <div class="nebula nebula1"></div>
        <div class="nebula nebula2"></div>
        <div class="nebula nebula3"></div>
    </div>
    <div id="stars-layer"></div>

    <div class="scroll-container">
        <!-- СЕКЦИЯ 1: ПРИВЕТСТВИЕ -->
        <section class="hero-section">
            <div class="command-panel">
                <h1>ОТЕЦ • ФЛОТ</h1>
                <div class="captain">ГЛАВНОКОМАНДУЮЩИЙ</div>
                <div class="father-name">С ДНЁМ РОЖДЕНИЯ!</div>
                <div style="font-size: 2rem; margin: 30px 0;">Капсулер, пилот, легенда</div>
                <div class="scroll-hint">▼ ПРОКРУТИ К ВЕРФИ С РЕАЛЬНЫМИ КОРАБЛЯМИ ▼</div>
            </div>
        </section>

        <!-- СЕКЦИЯ 2: ВЕРФЬ С РЕАЛЬНЫМИ КОРАБЛЯМИ -->
        <section class="assembly-section">
            <h2 class="section-title">⚙️ РЕАЛЬНАЯ ВЕРФЬ EVE ⚙️</h2>
            <div class="assembly-machine">
                <div class="stats-row">
                    <div class="stat-block"><div class="stat-label">⚡ МОЩНОСТЬ</div><div class="stat-number" id="powerStat">3.6 TT</div></div>
                    <div class="stat-block"><div class="stat-label">🔧 ДОКОВ</div><div class="stat-number" id="dockStat">12/16</div></div>
                    <div class="stat-block"><div class="stat-label">⭐ БАЛАНС</div><div class="stat-number" id="balanceStat">9.2T ISK</div></div>
                </div>

                <!-- КОНВЕЙЕР С РЕАЛЬНЫМ ИЗОБРАЖЕНИЕМ -->
                <div class="conveyor">
                    <div class="ship-display-area">
                        <!-- КОНТЕЙНЕР С РЕАЛЬНОЙ КАРТИНКОЙ -->
                        <div class="ship-image-container" id="shipImageContainer">
                            <img class="ship-real-image" id="shipRealImage" src="" alt="Корабль Eve Online" style="display: none;">
                            <div id="placeholderText" style="color: #99ccff; font-size: 2rem;">⚡ НАЖМИ ПОСТРОИТЬ ⚡</div>
                        </div>
                        <!-- НАЗВАНИЕ КОРАБЛЯ -->
                        <div class="ship-name-tag" id="shipNameDisplay">ОЖИДАНИЕ</div>

                        <div class="build-panel">
                            <button class="build-btn" id="buildShipBtn">🔨 ПОСТРОИТЬ КОРАБЛЬ</button>
                            <button class="build-btn" id="upgradeBtn" style="background: #2a3f60; border-color: #6bb0ff; padding: 20px 40px;">✨ УСКОРИТЬ</button>
                        </div>
                    </div>
                </div>

                <!-- ЛОГ СБОРКИ -->
                <div class="build-log" id="buildLog">
                    > Верфь реальных кораблей готова. Жми кнопку!
                </div>
            </div>
        </section>

        <!-- СЕКЦИЯ 3: ПЛЮШКИ -->
        <section class="booster-section">
            <h2 class="section-title">🌀 КОСМИЧЕСКИЕ ПЛЮШКИ</h2>
            <div class="booster-grid">
                <div class="booster-card"><div class="booster-icon">🛡️</div><div class="booster-title">ЩИТОВОЙ БУСТЕР</div><div class="booster-desc">+5000 HP к здоровью</div></div>
                <div class="booster-card"><div class="booster-icon">⚡</div><div class="booster-title">ВАРП-СТАБИЛИЗАТОР</div><div class="booster-desc">Никакие помехи не собьют</div></div>
                <div class="booster-card"><div class="booster-icon">🎁</div><div class="booster-title">КАРГО ЛЮБВИ</div><div class="booster-desc">Полный трюм тепла</div></div>
                <div class="booster-card"><div class="booster-icon">🚀</div><div class="booster-title">ИМПЛАНТЫ МУДРОСТИ</div><div class="booster-desc">Навыки прокачаны</div></div>
            </div>

            <div class="final-message">
                <div style="font-size: 2.5rem; margin-bottom: 20px;">✧ ПОЗДРАВЛЕНИЕ ОТ ЭКИПАЖА ✧</div>
                <p style="font-size: 1.8rem;">«Отец, ты — наш флагман. С тобой мы пройдём сквозь любые нуль-сектора. С днём рождения!»</p>
            </div>
            <div class="signature-code">[ОТЕЦ] • 05.03.2026 • EVE</div>
            <footer>CONCORD • FLY SAFE</footer>
        </section>
    </div>

    <script>
        (function() {
            // === ГЕНЕРАЦИЯ ЗВЁЗД ===
            const starsLayer = document.getElementById('stars-layer');
            if (starsLayer) {
                for (let i = 0; i < 300; i++) {
                    const s = document.createElement('div');
                    s.className = 'star';
                    s.style.width = (Math.random() * 4 + 1) + 'px';
                    s.style.height = s.style.width;
                    s.style.left = Math.random() * 100 + '%';
                    s.style.top = Math.random() * 100 + '%';
                    s.style.animationDelay = Math.random() * 5 + 's';
                    s.style.animationDuration = (Math.random() * 4 + 2) + 's';
                    starsLayer.appendChild(s);
                }
            }

            // === БАЗА РЕАЛЬНЫХ КОРАБЛЕЙ (ССЫЛКИ НА ИЗОБРАЖЕНИЯ) ===
            // Использую прямые ссылки на реальные арты кораблей Eve Online
            const ships = [
                { 
                    name: "Apocalypse", 
                    url: "https://images.evetech.net/types/642/icon?size=256", // официальная иконка
                    fallback: "https://webimg.cc/sample/apoc.jpg"
                },
                { 
                    name: "Megathron", 
                    url: "https://images.evetech.net/types/638/icon?size=256",
                },
                { 
                    name: "Raven", 
                    url: "https://images.evetech.net/types/621/icon?size=256",
                },
                { 
                    name: "Tempest", 
                    url: "https://images.evetech.net/types/645/icon?size=256",
                },
                { 
                    name: "Nyx", 
                    url: "https://images.evetech.net/types/23913/icon?size=256",
                },
                { 
                    name: "Thanatos", 
                    url: "https://images.evetech.net/types/23915/icon?size=256",
                },
                { 
                    name: "Hel", 
                    url: "https://images.evetech.net/types/23917/icon?size=256",
                },
                { 
                    name: "Erebus", 
                    url: "https://images.evetech.net/types/671/icon?size=256",
                },
                { 
                    name: "Moros", 
                    url: "https://images.evetech.net/types/19720/icon?size=256",
                },
                { 
                    name: "Naglfar", 
                    url: "https://images.evetech.net/types/19722/icon?size=256",
                }
            ];

            // Элементы интерфейса
            const shipImage = document.getElementById('shipRealImage');
            const shipNameDisplay = document.getElementById('shipNameDisplay');
            const buildLog = document.getElementById('buildLog');
            const buildBtn = document.getElementById('buildShipBtn');
            const upgradeBtn = document.getElementById('upgradeBtn');
            const placeholderText = document.getElementById('placeholderText');
            const powerStat = document.getElementById('powerStat');
            const dockStat = document.getElementById('dockStat');
            const balanceStat = document.getElementById('balanceStat');

            let buildCount = 0;
            let power = 3.6;
            let docks = 12;
            let balance = 9.2;

            function updateStatsUI() {
                powerStat.innerText = power.toFixed(1) + ' TT';
                dockStat.innerText = docks + '/16';
                balanceStat.innerText = balance.toFixed(1) + 'T ISK';
            }

            // Функция обновления картинки и названия
            function displayShip(ship) {
                // Показываем изображение, скрываем плейсхолдер
                shipImage.style.display = 'block';
                placeholderText.style.display = 'none';
                
                // Устанавливаем изображение (прямая ссылка с официального API Eve)
                shipImage.src = ship.url;
                
                // Обновляем название
                shipNameDisplay.innerText = ship.name;
                
                // Анимация
                shipImage.style.transition = 'filter 0.2s, transform 0.2s';
                shipImage.style.filter = 'drop-shadow(0 0 50px #ffaa33)';
                setTimeout(() => shipImage.style.filter = 'drop-shadow(0 0 30px #6ab5ff)', 300);
            }

            // Построить корабль
            if (buildBtn) {
                buildBtn.addEventListener('click', function() {
                    const randomIndex = Math.floor(Math.random() * ships.length);
                    const ship = ships[randomIndex];
                    displayShip(ship);

                    // Лог
                    const entry = document.createElement('div');
                    entry.innerHTML = '> Построен: ' + ship.name + ' (уровень ' + (Math.floor(Math.random()*5)+1) + ')';
                    buildLog.appendChild(entry);
                    buildLog.scrollTop = buildLog.scrollHeight;
                    if (buildLog.children.length > 6) buildLog.removeChild(buildLog.children[0]);

                    // Меняем статистику
                    buildCount++;
                    power = 3.6 + buildCount * 0.3;
                    docks = 12 + (buildCount % 5);
                    if (docks > 16) docks = 16;
                    balance = 9.2 - buildCount * 0.15;
                    if (balance < 1.0) balance = 1.0;
                    updateStatsUI();
                });
            }

            // Ускорение (плюшка)
            if (upgradeBtn) {
                upgradeBtn.addEventListener('click', function() {
                    buildLog.innerHTML += '\n> УСКОРЕНИЕ: все системы на 120%';
                    power += 1.5;
                    updateStatsUI();
                });
            }

            // Показываем первый корабль при загрузке (случайный)
            const startShip = ships[Math.floor(Math.random() * ships.length)];
            displayShip(startShip);
        })();
    </script>
</body>
</html>
